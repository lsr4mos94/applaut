    </partitioning>
    <connection>salesapp_get</connection>
    <sql>SELECT 
	DA1_CODPRO, 
	B1_GRUPO, 
	DA1_PRCVEN
FROM DA1010 
INNER JOIN SB1010 
ON B1_FILIAL = DA1_FILIAL AND B1_COD = DA1_CODPRO AND SB1010.D_E_L_E_T_ &lt;&gt; '*'
WHERE DA1010.D_E_L_E_T_ &lt;&gt; '*' 
AND DA1_CODTAB = '214'

</sql>
